{
  "name": "@open-ludo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.17",
    "@nestjs/platform-express": "11.1.17",
    "@nestjs/platform-socket.io": "11.1.17",
    "@nestjs/websockets": "11.1.17",
    "@open-ludo/contracts": "workspace:*",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "cors": "2.8.6",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.17",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.5.0",
    "prisma": "7.5.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "vite": "8.0.1",
    "vitest": "4.1.0"
  }
}
