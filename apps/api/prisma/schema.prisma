generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  moduleFormat = "esm"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserKind {
  guest
  registered
}

enum RoomStatus {
  waiting
  playing
  finished
}

enum WalletTransactionKind {
  ENTRY_FEE
  PAYOUT
  REFUND
}

enum MatchSettlementStatus {
  PENDING
  SETTLED
  CANCELLED
}

model User {
  id          String   @id @default(cuid())
  externalId  String   @unique
  kind        UserKind
  email       String?
  displayName String
  avatarKey   String   @default("pawn_red")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wallet      Wallet?
  roomPlayers RoomPlayer[]
  hostedRooms Room[]             @relation("RoomHost")
  transactions WalletTransaction[]
  wonSettlements MatchSettlement[] @relation("MatchSettlementWinner")
  guestMerges AccountMerge[]    @relation("AccountMergeGuest")
  upgradedGuests AccountMerge[] @relation("AccountMergeRegistered")
  friendshipsA Friendship[]      @relation("FriendshipUserA")
  friendshipsB Friendship[]      @relation("FriendshipUserB")
  sentFriendInvites FriendInvite[] @relation("FriendInviteInviter")
  consumedFriendInvites FriendInvite[] @relation("FriendInviteConsumedBy")
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  coinBalance Int      @default(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id           String                @id @default(cuid())
  userId       String
  settlementId String
  kind         WalletTransactionKind
  amount       Int
  createdAt    DateTime              @default(now())

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlement   MatchSettlement       @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([settlementId, createdAt])
  @@unique([settlementId, userId, kind])
}

model Room {
  id         String      @id @default(cuid())
  code       String      @unique
  hostUserId String
  status     RoomStatus  @default(waiting)
  maxPlayers Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  host       User        @relation("RoomHost", fields: [hostUserId], references: [id])
  players    RoomPlayer[]
  settlement MatchSettlement?
}

model RoomPlayer {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  isHost     Boolean  @default(false)
  isReady    Boolean  @default(false)
  joinedAt   DateTime @default(now())
  leftAt     DateTime?

  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

model MatchSettlement {
  id                 String                @id @default(cuid())
  roomId             String                @unique
  entryFee           Int
  pot                Int
  participantUserIds Json
  skippedUserIds     Json
  placementsJson     Json?
  winnerUserId       String?
  status             MatchSettlementStatus @default(PENDING)
  settledAt          DateTime?
  cancelledAt        DateTime?
  cancelledReason    String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  room               Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  winner             User?                 @relation("MatchSettlementWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  transactions       WalletTransaction[]

  @@index([status])
}

model AccountMerge {
  id               String   @id @default(cuid())
  guestUserId      String   @unique
  registeredUserId String
  createdAt        DateTime @default(now())

  guest            User     @relation("AccountMergeGuest", fields: [guestUserId], references: [id], onDelete: Cascade)
  registered       User     @relation("AccountMergeRegistered", fields: [registeredUserId], references: [id], onDelete: Cascade)

  @@index([registeredUserId, createdAt])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
}

model FriendInvite {
  id               String   @id @default(cuid())
  token            String   @unique
  inviterUserId    String
  consumedByUserId String?
  createdAt        DateTime @default(now())
  consumedAt       DateTime?

  inviter          User     @relation("FriendInviteInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  consumedBy       User?    @relation("FriendInviteConsumedBy", fields: [consumedByUserId], references: [id], onDelete: SetNull)

  @@index([inviterUserId, createdAt])
  @@index([consumedByUserId])
}
