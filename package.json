{
  "name": "open-ludo",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "pnpm check:deps-exact && turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "check:deps-exact": "node ./scripts/check-exact-deps.mjs"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3"
  }
}
